{
  "version": 2,
  "build": {
    "env": {
      "NODE_VERSION": "18"
    }
  },
  "functions": {
    "api/analyze.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/ping.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
